// Schéma Prisma — Lot 0 : socle minimal.
// Le modèle complet (docs/cadrage/10-modele-de-donnees.md) sera introduit
// progressivement : User complet au Lot 1, catalogue au Lot 2, suivi au Lot 3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder Lot 1 — volontairement minimal : l'authentification (hash Argon2id,
// sessions, etc.) arrive au Lot 1 avec sa propre migration.
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("users")
}
