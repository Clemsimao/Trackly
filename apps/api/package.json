{
  "name": "@trackly/api",
  "version": "0.1.0",
  "private": true,
  "description": "API Trackly — NestJS + Prisma + PostgreSQL",
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "prisma generate && tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.10.0",
    "@trackly/contracts": "workspace:*",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.3.0",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "prisma": "^6.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.12.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.2.0"
  }
}
