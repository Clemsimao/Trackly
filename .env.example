# ── Copier vers .env et adapter. Ne JAMAIS committer .env. ──

# API
PORT=3000
LOG_LEVEL=info
# Base locale lancée par `docker compose up -d postgres`
DATABASE_URL=postgresql://trackly:trackly@localhost:5432/trackly

# Base (docker compose dev)
POSTGRES_USER=trackly
POSTGRES_PASSWORD=trackly
POSTGRES_DB=trackly

# ── Production (deploy/compose.prod.yml, sur le Proxmox) ──
# GHCR_OWNER=<ton-user-github>
# TAG=latest
# CLOUDFLARE_TUNNEL_TOKEN=<token du tunnel, dashboard Cloudflare Zero Trust>
# POSTGRES_PASSWORD=<mot de passe fort généré>
