# ── Copier vers .env et adapter. Ne JAMAIS committer .env. ──

# API
PORT=3000
LOG_LEVEL=info
# Base locale lancée par `docker compose up -d postgres`
DATABASE_URL=postgresql://trackly:trackly@localhost:5432/trackly

# Base (docker compose dev)
POSTGRES_USER=trackly
POSTGRES_PASSWORD=trackly
POSTGRES_DB=trackly

# E-mails transactionnels. Sans clé, envoi désactivé et aucun jeton journalisé.
# RESEND_API_KEY=
# MAIL_FROM=Trackly <onboarding@resend.dev>
# URL publique du front (liens dans les e-mails)
APP_URL=http://localhost:5173

# Sources de métadonnées (Lot 2)
# TMDB : themoviedb.org → Paramètres → API → « Jeton d'accès en lecture à l'API » (v4)
TMDB_API_TOKEN=
# IGDB : dev.twitch.tv/console → Applications → Register (OAuth redirect: http://localhost)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Production (deploy/compose.prod.yml, sur le Proxmox) ──
# GHCR_OWNER=clemsimao   # minuscules (nom d'image Docker)
# TAG=latest
# CLOUDFLARE_TUNNEL_TOKEN=<token du tunnel, dashboard Cloudflare Zero Trust>
# POSTGRES_PASSWORD=<mot de passe fort généré>
# APP_URL=https://trackly.clemhouse.uk
# RESEND_API_KEY=<clé API Resend pour les e-mails réels>
